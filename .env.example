# Humforge local config example
# Copy to .env and fill only what you need.

# Telegram/OpenClaw adapter
TELEGRAM_BOT_TOKEN=
OPENCLAW_GATEWAY_URL=
OPENCLAW_GATEWAY_TOKEN=

# Optional STT providers
ASSEMBLYAI_API_KEY=
DEEPGRAM_API_KEY=
OPENAI_API_KEY=

# Optional AI/music providers
STABILITY_API_KEY=
ELEVENLABS_API_KEY=

# Local paths
HUMFORGE_PROJECTS_DIR=./projects
HUMFORGE_MEDIA_DIR=./media
